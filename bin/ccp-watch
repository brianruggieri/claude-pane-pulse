#!/usr/bin/env bash
# ccp-watch — Live debug monitor for Claude Code Pulse
# Streams JSONL debug events and flags issues in real-time.
#
# Usage:
#   ccp-watch                  # watch the latest debug log
#   ccp-watch /path/to/log     # watch a specific log file
#   ccp-watch --list           # list available debug logs
#   ccp-watch --help
#
# Companion to `ccp --debug-ccp`. Auto-launched in a split pane
# when debug mode is active in iTerm2.

set -euo pipefail

# Extend PATH — iTerm2 auto-pane and similar launchers may run without
# the user's shell profile, so common tool locations need to be explicit.
export PATH="/opt/homebrew/bin:/usr/local/bin:${HOME}/.local/bin:${HOME}/bin:${PATH}"

# jq is required for parsing JSONL events
if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not found in PATH." >&2
    echo "Install with: brew install jq (macOS) or apt install jq (Linux)" >&2
    echo "PATH=${PATH}" >&2
    exit 1
fi

LOG_DIR="${HOME}/.config/claude-code-pulse/logs"

# ── Pane title ─────────────────────────────────────────────────────────────
_set_pane_title() {
    if [[ "${TERM_PROGRAM:-}" == "Apple_Terminal" ]]; then
        printf '\033]2;%s\007' "$1"
    else
        printf '\033]1;%s\007' "$1"
        printf '\033]2;\007'
    fi
}

# ── Colors ─────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Help / flags ───────────────────────────────────────────────────────────
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "ccp-watch — Live debug monitor for Claude Code Pulse"
    echo ""
    echo "Usage:"
    echo "  ccp-watch                  Watch the latest debug log"
    echo "  ccp-watch /path/to/log     Watch a specific log file"
    echo "  ccp-watch --list           List available debug logs"
    echo "  ccp-watch --help           Show this help"
    echo ""
    echo "Auto-launched by 'ccp --debug-ccp' in iTerm2."
    echo "Can also be run standalone in a separate pane."
    exit 0
fi

if [[ "${1:-}" == "--list" ]]; then
    echo "Debug logs in ${LOG_DIR}/:"
    ls -lt "${LOG_DIR}"/debug.*.jsonl 2>/dev/null || echo "  (none found)"
    exit 0
fi

# ── State tracking ─────────────────────────────────────────────────────────
last_status=""
last_status_ts=""
last_event_ts=""
pending_summaries=0
delivered_summaries=0
total_errors=0
total_events=0

# ── Helpers ────────────────────────────────────────────────────────────────
alert() {
    local level="$1" msg="$2"
    local color="${NC}"
    case "${level}" in
        ERROR)   color="${RED}" ;;
        WARN)    color="${YELLOW}" ;;
        INFO)    color="${CYAN}" ;;
        OK)      color="${GREEN}" ;;
    esac
    printf "\n  ${color}${BOLD}[%s]${NC} ${color}%s${NC}\n" "${level}" "${msg}"
}

ts_to_epoch() {
    local _ts="${1%%.*}"
    # BSD (macOS): date -j -f fmt str +%s
    # GNU (Linux): date -d str +%s
    date -j -f "%Y-%m-%dT%H:%M:%S" "${_ts}" +%s 2>/dev/null \
        || date -d "${_ts}" +%s 2>/dev/null \
        || echo "0"
}

short_ts() {
    local ts="${1##*T}"
    echo "${ts%%.*}"
}

# Status classification reference — mirrors hook_runner.sh pre-tool logic
expected_status_for() {
    local tool="$1" cmd="$2"
    case "${tool}" in
        Edit|Write|MultiEdit|NotebookEdit) echo "Editing" ;;
        Read|Glob|Grep) echo "Reading" ;;
        WebFetch|WebSearch) echo "Browsing" ;;
        Task|Agent) echo "Delegating" ;;
        Bash)
            if echo "${cmd}" | grep -qE '(jest|vitest|pytest|mocha|rspec|go[[:space:]]test|cargo[[:space:]]test|phpunit|bun[[:space:]]test|npm[[:space:]]test|yarn[[:space:]]test)'; then
                echo "Testing"
            elif echo "${cmd}" | grep -qE '(webpack|esbuild|tsc[[:space:]]|vite.*build|cargo[[:space:]]build|make[[:space:]]|cmake|gradle|mvn[[:space:]]package|npm[[:space:]]run.*build|yarn.*build)'; then
                echo "Building"
            elif echo "${cmd}" | grep -qE '(npm[[:space:]]+(install|add|ci)|yarn[[:space:]]+(install|add)|pip[[:space:]]install|cargo[[:space:]]add)'; then
                echo "Installing"
            elif echo "${cmd}" | grep -qE 'git[[:space:]]+push'; then
                echo "Pushing"
            elif echo "${cmd}" | grep -qE 'git[[:space:]]+pull'; then
                echo "Pulling"
            elif echo "${cmd}" | grep -qE 'git[[:space:]]+merge'; then
                echo "Merging"
            elif echo "${cmd}" | grep -qE 'docker'; then
                echo "Docker"
            else
                echo "Running"
            fi
            ;;
        *) echo "${tool}" ;;
    esac
}

# ── Set initial pane title ─────────────────────────────────────────────────
_set_pane_title "🩺 Pulse Monitor"

# ── Banner ─────────────────────────────────────────────────────────────────
echo ""
echo -e "  ${MAGENTA}${BOLD}🩺 Pulse Monitor${NC}"
echo -e "  ${DIM}Real-time debug stream for Claude Code Pulse${NC}"
echo ""

# ── Find or wait for log ──────────────────────────────────────────────────
log="${1:-}"

if [[ -n "${log}" && -f "${log}" ]]; then
    echo -e "  ${GREEN}Log:${NC} $(basename "${log}")"
elif [[ -n "${log}" ]]; then
    # Log path given but file doesn't exist yet — wait for it
    echo -e "  ${DIM}Waiting for log: $(basename "${log}")...${NC}"
    while [[ ! -f "${log}" ]]; do
        sleep 0.5
    done
    echo -e "  ${GREEN}Log:${NC} $(basename "${log}")"
else
    # No argument — find the latest log
    echo -e "  ${DIM}Scanning for debug logs...${NC}"
    while true; do
        log=$(ls -t "${LOG_DIR}"/debug.*.jsonl 2>/dev/null | head -1) || true
        if [[ -n "${log}" && -f "${log}" ]]; then
            break
        fi
        printf "\r  ${DIM}Waiting for a debug log... (start ccp with --debug-ccp)${NC} "
        sleep 1
    done
    echo -e "\r  ${GREEN}Log:${NC} $(basename "${log}")                              "
fi

echo -e "  ${DIM}────────────────────────────────────────────────────${NC}"
echo ""

# ── Process events ─────────────────────────────────────────────────────────
tail -f "${log}" | while IFS= read -r line; do
    total_events=$((total_events + 1))

    # Parse fields
    src=$(printf '%s' "${line}" | jq -r '.src // ""' 2>/dev/null) || continue
    event=$(printf '%s' "${line}" | jq -r '.event // .mode // ""' 2>/dev/null) || continue
    ts=$(printf '%s' "${line}" | jq -r '.ts // ""' 2>/dev/null) || ts=""
    status=$(printf '%s' "${line}" | jq -r '.status // .new // ""' 2>/dev/null) || status=""
    tool=$(printf '%s' "${line}" | jq -r '.tool // ""' 2>/dev/null) || tool=""
    summary=$(printf '%s' "${line}" | jq -r '.summary // ""' 2>/dev/null) || summary=""

    # ── Session start — update pane title with project info ────────────
    if [[ "${event}" == "session_start" ]]; then
        session_title=$(printf '%s' "${line}" | jq -r '.title // ""' 2>/dev/null) || session_title=""
        dir_val=$(printf '%s' "${line}" | jq -r '.dir // ""' 2>/dev/null) || dir_val=""
        profile_val=$(printf '%s' "${line}" | jq -r '.profile // ""' 2>/dev/null) || profile_val=""
        ai_val=$(printf '%s' "${line}" | jq -r '.ai_context // ""' 2>/dev/null) || ai_val=""

        if [[ -n "${session_title}" ]]; then
            _set_pane_title "🩺 Pulse Monitor — ${session_title}"
        fi

        echo -e "  ${MAGENTA}${BOLD}Session Connected${NC}"
        echo -e "  ${DIM}Title:${NC}    ${session_title}"
        [[ -n "${dir_val}" ]] && echo -e "  ${DIM}Dir:${NC}      ${dir_val}"
        [[ -n "${profile_val}" ]] && echo -e "  ${DIM}Profile:${NC}  ${profile_val}"
        [[ "${ai_val}" == "true" ]] && echo -e "  ${DIM}AI:${NC}       enabled"
        echo -e "  ${DIM}────────────────────────────────────────────────────${NC}"
        echo ""
        continue
    fi

    # ── Normal event display (compact) ─────────────────────────────────
    detail=""
    case "${event}" in
        status_set|status_change)
            detail="${status}"
            ;;
        ai_summary)
            detail="-> ${summary}"
            ;;
        prompt_received)
            detail=$(printf '%s' "${line}" | jq -r '.prompt_preview // ""' 2>/dev/null | head -c 60) || detail=""
            ;;
        context_set)
            detail=$(printf '%s' "${line}" | jq -r '.context // ""' 2>/dev/null) || detail=""
            ;;
        *)
            detail="${status}"
            ;;
    esac

    color="${DIM}"
    case "${detail}" in
        *Error*|*failed*)   color="${RED}" ;;
        *passed*|*Commit*)  color="${GREEN}" ;;
        *Think*|*Test*|*Build*|*Edit*) color="${CYAN}" ;;
    esac

    printf "  ${DIM}%s${NC}  %-8s %-22s ${color}%s${NC}\n" \
        "$(short_ts "${ts}")" "${src}" "${event}" "${detail}"

    # ── Gap detection ──────────────────────────────────────────────────
    if [[ -n "${last_event_ts}" && -n "${ts}" ]]; then
        prev_sec=$(ts_to_epoch "${last_event_ts}")
        cur_sec=$(ts_to_epoch "${ts}")
        gap=$((cur_sec - prev_sec))
        if [[ ${gap} -gt 120 ]]; then
            alert "WARN" "Event gap: ${gap}s silence between events"
        fi
    fi
    last_event_ts="${ts}"

    # ── Stuck detection ────────────────────────────────────────────────
    if [[ "${event}" == "status_change" || "${event}" == "status_set" ]] && [[ -n "${status}" ]]; then
        if [[ -n "${last_status}" && -n "${last_status_ts}" && "${status}" != "${last_status}" ]]; then
            prev_sec=$(ts_to_epoch "${last_status_ts}")
            cur_sec=$(ts_to_epoch "${ts}")
            held=$((cur_sec - prev_sec))
            if [[ ${held} -gt 45 ]]; then
                alert "WARN" "Status '${last_status}' was held for ${held}s before changing"
            fi
        fi
        last_status="${status}"
        last_status_ts="${ts}"
    fi

    # ── Error detection ────────────────────────────────────────────────
    case "${status}" in
        *Error*|*failed*)
            total_errors=$((total_errors + 1))
            alert "ERROR" "${status} (tool=${tool}, errors so far: ${total_errors})"
            ;;
    esac

    # ── Status mismatch detection (real-time) ──────────────────────────
    if [[ "${event}" == "status_set" && -n "${tool}" ]]; then
        mode_val=$(printf '%s' "${line}" | jq -r '.mode // ""' 2>/dev/null) || mode_val=""
        if [[ "${mode_val}" == "pre-tool" ]]; then
            cmd_val=$(printf '%s' "${line}" | jq -r '.command // ""' 2>/dev/null) || cmd_val=""
            expected=$(expected_status_for "${tool}" "${cmd_val}")
            # Extract just the label from the emoji+label status string
            status_label=$(echo "${status}" | sed 's/^[^ ]* //')
            if [[ -n "${expected}" && "${status_label}" != "${expected}" ]]; then
                alert "WARN" "Status mismatch: tool=${tool} cmd='$(echo "${cmd_val}" | head -c 40)' got='${status}' expected='${expected}'"
            fi
        fi
    fi

    # ── Inline summary tracking ────────────────────────────────────────
    case "${event}" in
        ai_context_pending)
            pending_summaries=$((pending_summaries + 1))
            ;;
        ai_summary)
            delivered_summaries=$((delivered_summaries + 1))
            alert "OK" "Summary delivered: '${summary}' (${delivered_summaries}/${pending_summaries})"
            ;;
        inline_marker_miss)
            if [[ ${pending_summaries} -gt ${delivered_summaries} ]]; then
                cmd=$(printf '%s' "${line}" | jq -r '.command // ""' 2>/dev/null | head -c 40) || cmd=""
                outstanding=$((pending_summaries - delivered_summaries))
                miss_count=$(jq -n "[inputs | select(.event == \"inline_marker_miss\")] | length" "${log}" 2>/dev/null) || miss_count=0
                if [[ ${miss_count} -gt 5 && ${outstanding} -gt 0 ]]; then
                    alert "WARN" "Inline summary still pending after ${miss_count} Bash calls (cmd: ${cmd})"
                fi
            fi
            ;;
    esac

    # ── System message detection ───────────────────────────────────────
    if [[ "${event}" == "system_message_skipped" ]]; then
        sys_type=$(printf '%s' "${line}" | jq -r '.type // ""' 2>/dev/null) || sys_type=""
        alert "INFO" "System message filtered: ${sys_type} (not shown in title)"
    fi

    # ── Title anomaly detection (real-time) ────────────────────────────
    if [[ "${event}" == "title_anomaly" ]]; then
        anomaly_issues=$(printf '%s' "${line}" | jq -r '.issues // ""' 2>/dev/null) || anomaly_issues=""
        anomaly_preview=$(printf '%s' "${line}" | jq -r '.title_preview // ""' 2>/dev/null | head -c 80) || anomaly_preview=""
        alert "ERROR" "Title anomaly: ${anomaly_issues} — '${anomaly_preview}'"
    fi

    # ── Unknown status detection (real-time) ───────────────────────────
    if [[ "${event}" == "unknown_status" ]]; then
        unknown_val=$(printf '%s' "${line}" | jq -r '.status // ""' 2>/dev/null) || unknown_val=""
        alert "WARN" "Unknown status string: '${unknown_val}' — not in known set"
    fi

    # ── Idle transition ────────────────────────────────────────────────
    if [[ "${event}" == "idle_transition" ]]; then
        phrase=$(printf '%s' "${line}" | jq -r '.idle_phrase // ""' 2>/dev/null) || phrase=""
        printf "  ${DIM}  → idle: %s${NC}\n" "${phrase}"
    fi

    # ── Session end ────────────────────────────────────────────────────
    if [[ "${event}" == "session_end" ]]; then
        echo ""
        echo -e "  ${DIM}────────────────────────────────────────────────────${NC}"
        echo -e "  ${MAGENTA}${BOLD}Session Summary${NC}"
        echo -e "  Events:     ${total_events}"
        echo -e "  Errors:     ${total_errors}"
        echo -e "  Summaries:  ${delivered_summaries}/${pending_summaries} delivered"
        if [[ ${total_errors} -gt 0 ]]; then
            echo -e "  ${RED}${BOLD}Issues detected — review log with: ccp-watch --list${NC}"
        elif [[ ${pending_summaries} -gt ${delivered_summaries} ]]; then
            echo -e "  ${YELLOW}Dropped summaries detected${NC}"
        else
            echo -e "  ${GREEN}Clean session.${NC}"
        fi
        echo -e "  ${DIM}────────────────────────────────────────────────────${NC}"

        _set_pane_title "🩺 Pulse Monitor — Session Ended"
    fi

done
