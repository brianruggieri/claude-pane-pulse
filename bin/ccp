#!/usr/bin/env bash
# ccp - Claude Code Pulse: Dynamic terminal title manager for Claude Code
# Version: 1.0.0

set -euo pipefail

# Resolve symlinks so LIB_DIR points at the real install location,
# not the directory containing the ~/bin/ccp symlink.
_CCP_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "${_CCP_SCRIPT}" ]]; do
    _CCP_SCRIPT_DIR="$(cd "$(dirname "${_CCP_SCRIPT}")" && pwd)"
    _CCP_SCRIPT="$(readlink "${_CCP_SCRIPT}")"
    [[ "${_CCP_SCRIPT}" != /* ]] && _CCP_SCRIPT="${_CCP_SCRIPT_DIR}/${_CCP_SCRIPT}"
done
SCRIPT_DIR="$(cd "$(dirname "${_CCP_SCRIPT}")" && pwd)"
unset _CCP_SCRIPT _CCP_SCRIPT_DIR
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

# Source libraries
# shellcheck source=lib/core.sh
source "${LIB_DIR}/core.sh"
# shellcheck source=lib/title.sh
source "${LIB_DIR}/title.sh"
# shellcheck source=lib/session.sh
source "${LIB_DIR}/session.sh"
# shellcheck source=lib/monitor.sh
source "${LIB_DIR}/monitor.sh"
# shellcheck source=lib/hooks.sh
source "${LIB_DIR}/hooks.sh"

show_help() {
    cat << EOF
${GREEN}Claude Code Pulse${NC} v${VERSION} - Dynamic terminal titles for Claude Code

${BLUE}Usage:${NC}
    ${SCRIPT_NAME} [CCP OPTIONS] [NOTE] [DIRECTORY] [-- CLAUDE OPTIONS]

    With no arguments, the title is auto-detected from the git project name.
    Pass a NOTE to use a custom message instead (e.g. your task or context).
    Flags not consumed by ccp are forwarded to Claude. Use -- to pass anything
    that would otherwise be ambiguous.

${BLUE}Examples:${NC}
    ${SCRIPT_NAME}                              # auto: project name
    ${SCRIPT_NAME} "fixing the login bug"       # custom note as title
    ${SCRIPT_NAME} --pr 89 "Fix auth"
    ${SCRIPT_NAME} -c                           # resume last conversation
    ${SCRIPT_NAME} --model sonnet               # pass model to Claude
    ${SCRIPT_NAME} --permission-mode acceptEdits
    ${SCRIPT_NAME} "My task" -- --resume abc123 --model opus

${BLUE}Quick Formats:${NC}
    --pr NUMBER DESC        PR #NUMBER - DESC
    --issue NUMBER DESC     Issue #NUMBER - DESC
    --feature DESC          Feature: DESC
    --bug DESC              Bug: DESC
    --refactor DESC         Refactor: DESC

${BLUE}ccp Options:${NC}
    --auto-title            Auto-detect title from git branch (default)
    --no-dynamic            Disable dynamic updates (static title)
    --status-profile MODE   Status surface: quiet (default) or verbose
    --ai-context            Summarize prompts in title via claude-haiku (opt-in,
                            uses your Claude subscription — see docs/ai-context.md)
                            Privacy: prompt text is sent to Anthropic to generate
                            the summary. Do not enable if prompts contain secrets.
                            Also: export CCP_ENABLE_AI_CONTEXT=true for always-on
    --ai-context-strategy MODE
                            How AI context summaries are generated:
                              haiku   — separate claude-haiku call (default)
                              inline  — system prompt injection, zero extra API calls
                            Also: export CCP_AI_CONTEXT_STRATEGY=inline for always-on
    --debug-ccp             Enable structured JSONL debug logging to
                            ~/.config/claude-code-pulse/logs/
                            In iTerm2, auto-opens Pulse Monitor in a split pane.
                            Also: export CCP_DEBUG=true for always-on
    --goto TITLE            Re-open a previous session by title search
    --list, -l              List all active sessions
    --help, -h              Show this help
    --version, -v           Show version

${BLUE}Forwarded to Claude (common):${NC}
    -c, --continue          Resume most recent conversation
    -r, --resume [ID]       Resume by session ID
    --model <model>         Model (e.g. sonnet, opus, claude-sonnet-4-6)
    --permission-mode MODE  acceptEdits | bypassPermissions | default | dontAsk | plan
    --effort LEVEL          low | medium | high
    --dangerously-skip-permissions
    --system-prompt TEXT
    --append-system-prompt TEXT
    --add-dir DIRS          Additional allowed directories
    --allowedTools TOOLS
    --disallowedTools TOOLS
    --worktree [NAME]       Create a git worktree for this session
    --from-pr [VALUE]       Resume session linked to a PR
    --ide                   Connect to IDE on startup
    --verbose
    --debug [FILTER]
    (any other claude flag)

${BLUE}Features:${NC}
    • Dynamic status updates (Building, Testing, Pushing, etc.)
    • Tiered status profiles (quiet default, verbose full surface)
    • Animated progress indicators
    • Priority-based status display
    • Session tracking and resumption
    • Auto-detection from git branches
    • Welcome status on startup

${BLUE}Status Icons:${NC}
    🔨 Building    🧪 Testing     ✅ Tests passed    ❌ Tests failed
    💾 Committed   ⬆️ Pushing     📦 Installing      💭 Thinking
    🐛 Error       💤 Idle        🐳 Docker          🔀 Merging

For more info: https://github.com/brianruggieri/claude-code-pulse
EOF
}

show_version() {
    echo "ccp version ${VERSION}"
}

auto_detect_title() {
    local title=""
    local project_name
    project_name=$(basename "${PWD}")

    if git rev-parse --git-dir > /dev/null 2>&1; then
        local branch
        branch=$(git branch --show-current 2>/dev/null || echo "")

        if [[ -n "${branch}" ]]; then
            if [[ "${branch}" =~ ^(pr|pull|PR)/([0-9]+) ]]; then
                local pr_num="${BASH_REMATCH[2]}"
                local desc
                desc=$(echo "${branch}" | sed -E 's/^[^/]+\/[0-9]+[-_]?//' | tr '-_' ' ')
                title="PR #${pr_num} - ${desc}"
            elif [[ "${branch}" =~ ^(issue|fix|bug)/([0-9]+) ]]; then
                local issue_num="${BASH_REMATCH[2]}"
                local desc
                desc=$(echo "${branch}" | sed -E 's/^[^/]+\/[0-9]+[-_]?//' | tr '-_' ' ')
                title="Issue #${issue_num} - ${desc}"
            elif [[ "${branch}" =~ ^feature/ ]]; then
                local desc
                desc=$(echo "${branch}" | sed 's/^feature\///' | tr '-_' ' ')
                title="Feature: ${desc}"
            else
                # Plain branch (main, master, develop, etc.) — show the
                # project name with branch.  Disambiguates from iTerm2's
                # automatic directory prefix and makes multi-repo splits clear.
                title="${project_name} (${branch})"
            fi
        fi
    fi

    if [[ -z "${title}" ]]; then
        title="${project_name}"
    fi

    echo "${title}"
}

main() {
    local title=""
    local directory="${PWD}"
    local enable_dynamic=true
    local status_profile_cli=""
    local enable_ai_context="${CCP_ENABLE_AI_CONTEXT:-false}"
    local ai_context_strategy="${CCP_AI_CONTEXT_STRATEGY:-haiku}"
    local enable_debug_ccp="${CCP_DEBUG:-false}"
    local claude_args=()

    # Initialize state directory
    init_state_dir

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            # ── ccp-specific flags ────────────────────────────────────────────
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --list|-l)
                if ! check_dependencies; then
                    exit 1
                fi
                list_sessions
                exit 0
                ;;
            --no-dynamic)
                enable_dynamic=false
                shift
                ;;
            --debug-ccp)
                enable_debug_ccp=true
                shift
                ;;
            --ai-context)
                enable_ai_context=true
                shift
                ;;
            --ai-context-strategy)
                shift
                if [[ $# -lt 1 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --ai-context-strategy haiku|inline"
                    exit 1
                fi
                ai_context_strategy="$1"
                shift
                ;;
            --status-profile)
                shift
                if [[ $# -lt 1 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --status-profile quiet|verbose"
                    exit 1
                fi
                status_profile_cli="$1"
                shift
                ;;
            --auto-title)
                shift  # auto-title is the default; flag retained for back-compat
                ;;
            --pr)
                shift
                if [[ $# -lt 2 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --pr NUMBER DESCRIPTION"
                    exit 1
                fi
                local pr_num="$1"
                shift
                title="PR #${pr_num} - $1"
                shift
                ;;
            --issue)
                shift
                if [[ $# -lt 2 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --issue NUMBER DESCRIPTION"
                    exit 1
                fi
                local issue_num="$1"
                shift
                title="Issue #${issue_num} - $1"
                shift
                ;;
            --feature)
                shift
                title="Feature: $1"
                shift
                ;;
            --bug)
                shift
                title="Bug: $1"
                shift
                ;;
            --refactor)
                shift
                title="Refactor: $1"
                shift
                ;;
            --goto)
                # Re-open a previous ccp session by title search (cd to its directory).
                # Renamed from --continue to avoid conflict with Claude's -c/--continue.
                shift
                if [[ $# -lt 1 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --goto TITLE"
                    exit 1
                fi
                local search="$1"
                directory=$(find_session "${search}")
                if [[ -z "${directory}" ]]; then
                    log_warning "Could not find session matching '${search}'"
                    echo "Available sessions:"
                    list_sessions
                    exit 1
                fi
                title=$(find_session_title "${search}")
                shift
                ;;

            # ── Flags forwarded to Claude ─────────────────────────────────────
            # Flags with no value
            -c|--continue|\
            --dangerously-skip-permissions|--allow-dangerously-skip-permissions|\
            --verbose|--ide|--no-ide|--fork-session|--chrome|--no-chrome|\
            --no-session-persistence|--include-partial-messages|\
            --replay-user-messages|--strict-mcp-config|--mcp-debug)
                claude_args+=("$1")
                shift
                ;;
            # Flags with a required value
            --model|--permission-mode|--effort|--system-prompt|\
            --append-system-prompt|--debug-file|--session-id|\
            --output-format|--input-format|--settings|--setting-sources|\
            --fallback-model|--max-budget-usd|--json-schema|--agent)
                if [[ $# -lt 2 ]]; then
                    log_error "Flag $1 requires a value"
                    exit 1
                fi
                claude_args+=("$1" "$2")
                shift 2
                ;;
            # Flags with an optional value (collect next arg if it isn't a flag)
            -r|--resume|--from-pr|-w|--worktree|-d|--debug)
                claude_args+=("$1")
                shift
                if [[ $# -gt 0 && "$1" != -* ]]; then
                    claude_args+=("$1")
                    shift
                fi
                ;;
            # Flags that accept one-or-more values (collect next arg if not a flag)
            --add-dir|--allowedTools|--allowed-tools|--disallowedTools|\
            --disallowed-tools|--mcp-config|--tools|--betas|--plugin-dir|\
            --file|--agents)
                claude_args+=("$1")
                shift
                while [[ $# -gt 0 && "$1" != -* ]]; do
                    claude_args+=("$1")
                    shift
                done
                ;;

            # ── Explicit passthrough separator ────────────────────────────────
            --)
                shift
                while [[ $# -gt 0 ]]; do
                    claude_args+=("$1")
                    shift
                done
                ;;

            # ── Unknown dash-flags: forward to Claude ─────────────────────────
            -*)
                claude_args+=("$1")
                shift
                ;;

            # ── Positional args: ccp title and optional directory ─────────────
            *)
                if [[ -z "${title}" ]]; then
                    title="$1"
                elif [[ -d "$1" ]]; then
                    directory="$1"
                else
                    title="${title} $1"
                fi
                shift
                ;;
        esac
    done

    # Resolve title: explicit arg wins; auto-detect is the default fallback.
    # Passing a positional title (e.g. ccp "my note") disables auto-detect so
    # the user's message is used as-is.
    if [[ -z "${title}" ]]; then
        title=$(auto_detect_title)
        log_info "Auto-detected: ${title}"
    fi

    # Resolve status profile with precedence:
    #   CLI flag > environment variable > default quiet.
    local status_profile="${status_profile_cli:-${CCP_STATUS_PROFILE:-quiet}}"
    case "${status_profile}" in
        quiet|verbose)
            ;;
        *)
            log_error "Invalid status profile '${status_profile}'. Use: quiet or verbose."
            exit 1
            ;;
    esac
    export CCP_STATUS_PROFILE="${status_profile}"

    # Resolve AI context strategy with precedence:
    #   CLI flag > environment variable > default haiku.
    case "${ai_context_strategy}" in
        haiku|inline)
            ;;
        *)
            log_error "Invalid AI context strategy '${ai_context_strategy}'. Use: haiku or inline."
            exit 1
            ;;
    esac
    export CCP_AI_CONTEXT_STRATEGY="${ai_context_strategy}"

    # Setup debug logging if enabled
    if [[ "${enable_debug_ccp}" = true ]]; then
        local log_dir="${STATE_DIR}/logs"
        mkdir -p "${log_dir}"

        # Prune debug logs from dead sessions (PID embedded in filename)
        local _old_log _old_pid
        for _old_log in "${log_dir}"/debug.*.jsonl; do
            [[ -f "${_old_log}" ]] || continue
            _old_pid=$(basename "${_old_log}" .jsonl)
            _old_pid="${_old_pid##*.}"
            if [[ "${_old_pid}" =~ ^[0-9]+$ ]] && ! kill -0 "${_old_pid}" 2>/dev/null; then
                rm -f "${_old_log}"
            fi
        done

        local log_ts
        log_ts=$(date +"%Y%m%d-%H%M%S")
        export CCP_DEBUG_LOG="${log_dir}/debug.${log_ts}.$$.jsonl"
        export CCP_DEBUG_JSONL="true"
        # Write session start event
        local _start_ts
        _start_ts=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")
        jq -cn \
            --arg ts "${_start_ts}" \
            --arg pid "$$" \
            --arg title "${title}" \
            --arg dir "${directory}" \
            --arg profile "${status_profile}" \
            --arg ai_ctx "${enable_ai_context}" \
            --arg ai_strat "${ai_context_strategy}" \
            '{ts:$ts, src:"session", pid:$pid, event:"session_start", title:$title, dir:$dir, profile:$profile, ai_context:$ai_ctx, ai_strategy:$ai_strat}' \
            >> "${CCP_DEBUG_LOG}" 2>/dev/null || true
    fi

    # Check dependencies
    if ! check_dependencies; then
        exit 1
    fi

    # Setup cleanup on exit (ccp_settings_file populated below if dynamic mode)
    ccp_settings_file=""
    _ccp_cleanup() {
        # Log session end if debug is active
        if [[ -n "${CCP_DEBUG_LOG:-}" && "${CCP_DEBUG_JSONL:-}" == "true" ]]; then
            local _end_ts
            _end_ts=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z" 2>/dev/null || echo "")
            jq -cn \
                --arg ts "${_end_ts}" \
                --arg pid "$$" \
                '{ts:$ts, src:"session", pid:$pid, event:"session_end"}' \
                >> "${CCP_DEBUG_LOG}" 2>/dev/null || true
        fi
        cleanup_session
        cleanup_monitor
        teardown_ccp_hooks "${ccp_settings_file}"
        rm -f "${CCP_STATUS_FILE:-}" "${CCP_CONTEXT_FILE:-}" "${CCP_BRANCH_FILE:-}" \
             "${STATE_DIR}/inline_captured.$$"
    }
    trap '_ccp_cleanup' EXIT

    # Set initial title and save session
    set_title "${title}"
    save_session "${title}" "${directory}"

    # Show startup status
    log_success "Starting: ${title}"
    log_info "Directory: ${directory}"
    if [[ "${enable_dynamic}" = true ]]; then
        log_info "Dynamic titles: ${GREEN}enabled${NC}"
        log_info "Status profile: ${CCP_STATUS_PROFILE}"
        if [[ "${enable_ai_context}" = true ]]; then
            if [[ "${ai_context_strategy}" == "inline" ]]; then
                log_info "AI context:     ${GREEN}enabled${NC} (inline — summary via system prompt, no extra API calls)"
            else
                log_info "AI context:     ${GREEN}enabled${NC} (prompts summarized via claude-haiku — uses your subscription)"
            fi
        fi
        if [[ "${enable_debug_ccp}" = true ]]; then
            log_info "Debug log:      ${YELLOW}${CCP_DEBUG_LOG}${NC}"
        fi
    fi
    if [[ ${#claude_args[@]} -gt 0 ]]; then
        log_info "Claude args: ${claude_args[*]}"
    fi
    echo ""

    # Change to target directory
    cd "${directory}"

    # Prevent Claude Code from overriding our terminal title.
    # Without this, Claude Code's TUI sets the title to "* Claude Code" on
    # startup and wins any escape-sequence battle. With it, we own the title.
    export CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1

    # Launch Claude Code
    local claude_cmd
    claude_cmd=$(get_claude_cmd)

    if [[ "${enable_dynamic}" = true ]]; then
        # Export hook file paths so monitor and hook_runner.sh can share them
        export CCP_STATUS_FILE="${STATE_DIR}/status.$$.txt"
        export CCP_CONTEXT_FILE="${STATE_DIR}/context.$$.txt"
        export CCP_BRANCH_FILE="${STATE_DIR}/branch.$$.txt"
        export CCP_HOOK_RUNNER="${LIB_DIR}/hook_runner.sh"

        # Export AI context opt-in flag for hook_runner.sh
        export CCP_ENABLE_AI_CONTEXT="${enable_ai_context}"

        # Export project name and branch for the title prefix
        CCP_PROJECT_NAME=$(basename "${directory}")
        if git -C "${directory}" rev-parse --git-dir > /dev/null 2>&1; then
            CCP_BRANCH_NAME=$(git -C "${directory}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
        else
            CCP_BRANCH_NAME=""
        fi
        export CCP_PROJECT_NAME CCP_BRANCH_NAME
        export CCP_SESSION_PID=$$

        # Write welcome status — shown immediately on startup.
        # Overwritten by the first hook event (UserPromptSubmit → "💭 Thinking").
        local _welcome_name
        _welcome_name=$(git -C "${directory}" config user.name 2>/dev/null \
            | awk '{print $1}') || _welcome_name=""
        [[ -z "${_welcome_name}" ]] && _welcome_name="${USER:-}"
        if [[ -n "${_welcome_name}" ]]; then
            printf '%s' "👋 Welcome back, ${_welcome_name}" > "${CCP_STATUS_FILE}"
        fi

        # Inject hooks into the project's .claude/settings.local.json
        ccp_settings_file=$(setup_ccp_hooks "${directory}" "${CCP_HOOK_RUNNER}")

        # Inline AI context: inject a system prompt instruction asking Claude
        # to echo a structured task summary as its first action.  The summary
        # is captured by the PostToolUse hook (see hook_runner.sh post-tool).
        if [[ "${enable_ai_context}" = true && "${ai_context_strategy}" == "inline" ]]; then
            local _ccp_inline_prompt
            _ccp_inline_prompt="[CCP Terminal Title] As your very first action, run a single bash command: echo 'CCP_TASK_SUMMARY_$$:' followed by a 3-5 word title-case summary of the user's task. Example: echo 'CCP_TASK_SUMMARY_$$:Fix JWT Validation Bug'. Do this once, then proceed with your work normally."
            claude_args+=("--append-system-prompt" "${_ccp_inline_prompt}")
        fi

        # Start background title updater, then run Claude directly.
        title_updater "${title}"

        # Auto-open Pulse Monitor in a split pane (iTerm2 + debug mode)
        if [[ "${enable_debug_ccp}" = true && "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
            local watch_cmd="${SCRIPT_DIR}/ccp-watch"
            if [[ -x "${watch_cmd}" ]]; then
                # Launch via login shell so the user's full PATH is available
                local _user_shell="${SHELL:-/bin/bash}"
                local _as_cmd
                _as_cmd="tell application \"iTerm2\" to tell current session of current tab of current window to split horizontally with default profile command \"${_user_shell} -l -c '\\\"${watch_cmd}\\\" \\\"${CCP_DEBUG_LOG}\\\"'\""
                osascript -e "${_as_cmd}" >/dev/null 2>&1 &
                disown 2>/dev/null || true
            fi
        fi

        "${claude_cmd}" ${claude_args[@]+"${claude_args[@]}"}
    else
        "${claude_cmd}" ${claude_args[@]+"${claude_args[@]}"}
    fi
}

main "$@"
