#!/usr/bin/env bash
# ccp - Claude Pane Pulse: Dynamic terminal title manager for Claude Code
# Version: 1.0.0

set -euo pipefail

# Resolve symlinks so LIB_DIR points at the real install location,
# not the directory containing the ~/bin/ccp symlink.
_CCP_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "${_CCP_SCRIPT}" ]]; do
    _CCP_SCRIPT_DIR="$(cd "$(dirname "${_CCP_SCRIPT}")" && pwd)"
    _CCP_SCRIPT="$(readlink "${_CCP_SCRIPT}")"
    [[ "${_CCP_SCRIPT}" != /* ]] && _CCP_SCRIPT="${_CCP_SCRIPT_DIR}/${_CCP_SCRIPT}"
done
SCRIPT_DIR="$(cd "$(dirname "${_CCP_SCRIPT}")" && pwd)"
unset _CCP_SCRIPT _CCP_SCRIPT_DIR
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

# Source libraries
# shellcheck source=lib/core.sh
source "${LIB_DIR}/core.sh"
# shellcheck source=lib/title.sh
source "${LIB_DIR}/title.sh"
# shellcheck source=lib/session.sh
source "${LIB_DIR}/session.sh"
# shellcheck source=lib/monitor.sh
source "${LIB_DIR}/monitor.sh"
# shellcheck source=lib/hooks.sh
source "${LIB_DIR}/hooks.sh"

show_help() {
    cat << EOF
${GREEN}Claude Pane Pulse${NC} v${VERSION} - Dynamic terminal titles for Claude Code

${BLUE}Usage:${NC}
    ${SCRIPT_NAME} [OPTIONS] [NOTE] [DIRECTORY]

    With no arguments, the title is auto-detected from the git project name.
    Pass a NOTE to use a custom message instead (e.g. your task or context).

${BLUE}Examples:${NC}
    ${SCRIPT_NAME}                          # auto: project name
    ${SCRIPT_NAME} "fixing the login bug"   # custom note as title
    ${SCRIPT_NAME} --pr 89 "Fix auth"
    ${SCRIPT_NAME} --auto-title             # same as no args
    ${SCRIPT_NAME} --list

${BLUE}Quick Formats:${NC}
    --pr NUMBER DESC        PR #NUMBER - DESC
    --issue NUMBER DESC     Issue #NUMBER - DESC
    --feature DESC          Feature: DESC
    --bug DESC              Bug: DESC
    --refactor DESC         Refactor: DESC

${BLUE}Options:${NC}
    --auto-title            Auto-detect title from git branch
    --no-dynamic            Disable dynamic updates (static title)
    --continue TITLE        Resume session by title search
    --list, -l              List all active sessions
    --help, -h              Show this help
    --version, -v           Show version

${BLUE}Features:${NC}
    • Dynamic status updates (Building, Testing, Pushing, etc.)
    • Animated progress indicators
    • Priority-based status display
    • Session tracking and resumption
    • Auto-detection from git branches

${BLUE}Status Icons:${NC}
    🔨 Building    🧪 Testing     ✅ Tests passed    ❌ Tests failed
    💾 Committed   ⬆️ Pushing     📦 Installing      💭 Thinking
    🐛 Error       💤 Idle        🐳 Docker          🔀 Merging

For more info: https://github.com/brianruggieri/claude-pane-pulse
EOF
}

show_version() {
    echo "ccp version ${VERSION}"
}

auto_detect_title() {
    local title=""
    local project_name
    project_name=$(basename "${PWD}")

    if git rev-parse --git-dir > /dev/null 2>&1; then
        local branch
        branch=$(git branch --show-current 2>/dev/null || echo "")

        if [[ -n "${branch}" ]]; then
            if [[ "${branch}" =~ ^(pr|pull|PR)/([0-9]+) ]]; then
                local pr_num="${BASH_REMATCH[2]}"
                local desc
                desc=$(echo "${branch}" | sed -E 's/^[^/]+\/[0-9]+[-_]?//' | tr '-_' ' ')
                title="PR #${pr_num} - ${desc}"
            elif [[ "${branch}" =~ ^(issue|fix|bug)/([0-9]+) ]]; then
                local issue_num="${BASH_REMATCH[2]}"
                local desc
                desc=$(echo "${branch}" | sed -E 's/^[^/]+\/[0-9]+[-_]?//' | tr '-_' ' ')
                title="Issue #${issue_num} - ${desc}"
            elif [[ "${branch}" =~ ^feature/ ]]; then
                local desc
                desc=$(echo "${branch}" | sed 's/^feature\///' | tr '-_' ' ')
                title="Feature: ${desc}"
            else
                # Plain branch (main, master, develop, etc.) — show the
                # project name with branch.  Disambiguates from iTerm2's
                # automatic directory prefix and makes multi-repo splits clear.
                title="${project_name} (${branch})"
            fi
        fi
    fi

    if [[ -z "${title}" ]]; then
        title="${project_name}"
    fi

    echo "${title}"
}

main() {
    local title=""
    local directory="${PWD}"
    local enable_dynamic=true

    # Initialize state directory
    init_state_dir

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --list|-l)
                if ! check_dependencies; then
                    exit 1
                fi
                list_sessions
                exit 0
                ;;
            --no-dynamic)
                enable_dynamic=false
                shift
                ;;
            --auto-title)
                shift  # auto-title is the default; flag retained for back-compat
                ;;
            --pr)
                shift
                if [[ $# -lt 2 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --pr NUMBER DESCRIPTION"
                    exit 1
                fi
                local pr_num="$1"
                shift
                title="PR #${pr_num} - $1"
                shift
                ;;
            --issue)
                shift
                if [[ $# -lt 2 ]]; then
                    log_error "Usage: ${SCRIPT_NAME} --issue NUMBER DESCRIPTION"
                    exit 1
                fi
                local issue_num="$1"
                shift
                title="Issue #${issue_num} - $1"
                shift
                ;;
            --feature)
                shift
                title="Feature: $1"
                shift
                ;;
            --bug)
                shift
                title="Bug: $1"
                shift
                ;;
            --refactor)
                shift
                title="Refactor: $1"
                shift
                ;;
            --continue)
                shift
                local search="$1"
                directory=$(find_session "${search}")
                if [[ -z "${directory}" ]]; then
                    log_warning "Could not find session matching '${search}'"
                    echo "Available sessions:"
                    list_sessions
                    exit 1
                fi
                title=$(find_session_title "${search}")
                shift
                ;;
            *)
                if [[ -z "${title}" ]]; then
                    title="$1"
                elif [[ -d "$1" ]]; then
                    directory="$1"
                else
                    title="${title} $1"
                fi
                shift
                ;;
        esac
    done

    # Resolve title: explicit arg wins; auto-detect is the default fallback.
    # Passing a positional title (e.g. ccp "my note") disables auto-detect so
    # the user's message is used as-is.
    if [[ -z "${title}" ]]; then
        title=$(auto_detect_title)
        log_info "Auto-detected: ${title}"
    fi

    # Check dependencies
    if ! check_dependencies; then
        exit 1
    fi

    # Setup cleanup on exit (ccp_settings_file populated below if dynamic mode)
    local ccp_settings_file=""
    trap 'cleanup_session; cleanup_monitor; teardown_ccp_hooks "${ccp_settings_file}"; rm -f "${CCP_STATUS_FILE:-}" "${CCP_CONTEXT_FILE:-}"' EXIT

    # Set initial title and save session
    set_title "${title}"
    save_session "${title}" "${directory}"

    # Show startup status
    log_success "Starting: ${title}"
    log_info "Directory: ${directory}"
    if [[ "${enable_dynamic}" = true ]]; then
        log_info "Dynamic titles: ${GREEN}enabled${NC}"
    fi
    echo ""

    # Change to target directory
    cd "${directory}"

    # Prevent Claude Code from overriding our terminal title.
    # Without this, Claude Code's TUI sets the title to "* Claude Code" on
    # startup and wins any escape-sequence battle. With it, we own the title.
    export CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1

    # Launch Claude Code
    if [[ "${enable_dynamic}" = true ]]; then
        # Export hook file paths so monitor and hook_runner.sh can share them
        export CCP_STATUS_FILE="${STATE_DIR}/status.$$.txt"
        export CCP_CONTEXT_FILE="${STATE_DIR}/context.$$.txt"
        export CCP_HOOK_RUNNER="${LIB_DIR}/hook_runner.sh"

        # Export project name and branch for the title prefix
        CCP_PROJECT_NAME=$(basename "${directory}")
        if git -C "${directory}" rev-parse --git-dir > /dev/null 2>&1; then
            CCP_BRANCH_NAME=$(git -C "${directory}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
        else
            CCP_BRANCH_NAME=""
        fi
        export CCP_PROJECT_NAME CCP_BRANCH_NAME

        # Inject hooks into the project's .claude/settings.local.json
        ccp_settings_file=$(setup_ccp_hooks "${directory}" "${CCP_HOOK_RUNNER}")

        monitor_claude_output "${title}"
    else
        local claude_cmd
        claude_cmd=$(get_claude_cmd)
        "${claude_cmd}"
    fi
}

main "$@"
